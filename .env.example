# Supabase — baza de date (obligatoriu pe Vercel)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Panou administrare (/admin)
ADMIN_PASSWORD=alege-o-parola-puternica
# Opțional — secret separat pentru cookie-uri de sesiune
# ADMIN_SESSION_SECRET=alt-string-lung-random

# Email la rezervare nouă (opțional, dar recomandat)
# Cont gratuit: https://resend.com
RESEND_API_KEY=re_...
SALON_NOTIFY_EMAIL=cristina@exemplu.ro
# După verificarea domeniului în Resend:
# RESEND_FROM_EMAIL=Rezervări <noreply@domeniul-tau.ro>
